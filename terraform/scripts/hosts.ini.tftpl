[bastion_host]
bastion ansible_host=${bastion_public_ip} ansible_user=ec2-user ansible_ssh_private_key_file=${private_key_path}

[app]
app-1 ansible_host=${app_1_private_ip} ansible_user=ec2-user ansible_ssh_private_key_file=${private_key_path}
app-2 ansible_host=${app_2_private_ip} ansible_user=ec2-user ansible_ssh_private_key_file=${private_key_path}

[app:vars]
ansible_ssh_common_args='-o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -o ProxyCommand="ssh -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -W %h:%p -q -i ${private_key_path} ec2-user@${bastion_public_ip}"'