[bastion]
bastion ansible_host=${bastion_public_ip} ansible_user=ec2-user ansible_ssh_private_key_file=${private_key_path}

[app]
app-1 ansible_host=${app_1_private_ip} ansible_user=ec2-user
app-2 ansible_host=${app_2_private_ip} ansible_user=ec2-user

[app:vars]
ansible_ssh_common_args='-o ProxyCommand="ssh -W %%h:%%p -q -i ${private_key_path} ec2-user@${bastion_public_ip}"'